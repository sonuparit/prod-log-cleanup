# ==============================
# Simulate cleanup
# ==============================

DRY_RUN=true

# ==============================
# Show output on screen
# ==============================

LOG_TO_SCREEN=true

# ==============================
# Journal Cleanup Configuration
# ==============================

JOURNAL_LOG_DAYS=7          # Retain logs for 7 days
JOURNAL_LOG_SIZE=50         # Max size in MB
JOURNAL_LOG_FILE_LIMIT=10   # Max number of files

# ==============================
# Directory Cleanup Configuration
# ==============================

LOG_DIR=(               # Directories to be cleaned
"/var/log"
"/var/lib/docker"
"/var/lib/kubelet"
"/tmp"
)

DIR_LOG_DAYS=7          # Retain logs for 7 days
DIR_LOG_SIZE=50         # Max size in MB

# ==============================
# Cron Configuration
# ==============================

CRON_JOB=true
CRON_SCHEDULE="0 2 * * *"

# ==============================
# Directory Cleanup Configuration
# ==============================

SLACK_WEBHOOK=""
EMAIL_TO=""
EMAIL_FROM=""       # must match mstp config