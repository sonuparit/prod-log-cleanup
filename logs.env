# journalctl logs
JOURNAL_LOG_DAYS=7
JOURNAL_LOG_SIZE=500
JOURNAL_LOG_FILE_LIMIT=10

# directories to scan
LOG_DIR=(
"/var/log"
"/var/lib/docker"
"/var/lib/kubelet"
"/tmp"
)

DIR_LOG_DAYS=7
DIR_LOG_SIZE=50
DIR_LOG_FILE_LIMIT=5

# cron automation
CRON_JOB=TRUE
VALUE="0 2 * * *"

# notifications
SLACK_WEBHOOK="https://hooks.slack.com/services/..."
EMAIL_ADDRESS="youremail@address.com"